#!/bin/sh

MERGE_BASE=$(git merge-base --fork-point origin/master HEAD 2>/dev/null || git rev-parse HEAD)
PUSH_FILES=$(git diff --name-only "$MERGE_BASE"...HEAD 2>/dev/null || true)

# --- Test file staleness check ---
# src/ が変更された場合、tests/ も更新されたか警告（pre-push 固有）
if echo "$PUSH_FILES" | grep -qE "^src/"; then
  if echo "$PUSH_FILES" | grep -qE "^tests/"; then
    echo "Test files updated."
  else
    echo ""
    echo "⚠️  Warning: src/ files changed but tests/ was NOT updated."
    echo "   Consider adding or updating tests for the changed source code."
    echo ""
  fi
fi

# --- Schema consistency check (local in-memory DB) ---
pnpm exec vitest run tests/db/schema-consistency.test.ts

# --- Production schema drift detection ---
# If .env.local is present, load Turso credentials and check that the
# production DB schema matches schema.ts.  This catches drift when columns
# were added to schema.ts but drizzle-kit push was never run against Turso.
ENV_FILE="$(git rev-parse --show-toplevel)/.env.local"
if [ -f "$ENV_FILE" ]; then
  TURSO_URL=$(grep -E "^TURSO_DATABASE_URL=" "$ENV_FILE" | head -1 | cut -d= -f2-)
  TURSO_TOKEN=$(grep -E "^TURSO_AUTH_TOKEN=" "$ENV_FILE" | head -1 | cut -d= -f2-)
  if [ -n "$TURSO_URL" ] && [ -n "$TURSO_TOKEN" ]; then
    TURSO_DATABASE_URL="$TURSO_URL" TURSO_AUTH_TOKEN="$TURSO_TOKEN" \
      scripts/check-prod-schema.sh
  fi
fi
